generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum SupportRequestType {
  WARRANTY
  RETURN
}

enum SupportRequestStatus {
  OPEN
  PROCESSING
  RESOLVED
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  phone        String?
  address      String?
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true)
  orders       Order[]
  questions    CustomerQuestion[]
  reviews      Review[]
  supportRequests SupportRequest[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?   @db.Text
  imageUrl    String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id          Int         @id @default(autoincrement())
  categoryId  Int
  supplierId  Int?
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  supplier    Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  name        String
  slug        String      @unique
  sku         String      @unique
  brand       String?
  description String?     @db.Text
  price       Decimal     @db.Decimal(12, 2)
  salePrice   Decimal?    @db.Decimal(12, 2)
  stock       Int         @default(0)
  warranty    String?
  isFeatured  Boolean     @default(false)
  isActive    Boolean     @default(true)
  images      ProductImage[]
  attributes  ProductAttribute[]
  variants    ProductVariant[]
  orderItems  OrderItem[]
  reviews     Review[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
  @@index([supplierId])
  @@map("products")
}

model ProductAttribute {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_attributes")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id         Int      @id @default(autoincrement())
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  sku        String   @unique
  options    Json?
  priceDelta Decimal  @default(0) @db.Decimal(12, 2)
  stock      Int      @default(0)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  orderItems OrderItem[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
  @@map("product_variants")
}

model Order {
  id              Int           @id @default(autoincrement())
  userId          Int?
  provinceId      Int?
  shipperId       Int?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  province        Province?     @relation(fields: [provinceId], references: [id], onDelete: SetNull)
  shipper         Shipper?      @relation(fields: [shipperId], references: [id], onDelete: SetNull)
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String        @db.Text
  note            String?       @db.Text
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  subtotal        Decimal       @db.Decimal(12, 2)
  shippingFee     Decimal       @default(0) @db.Decimal(12, 2)
  discountTotal   Decimal       @default(0) @db.Decimal(12, 2)
  couponCode      String?
  total           Decimal       @db.Decimal(12, 2)
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  supportRequests SupportRequest[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([provinceId])
  @@index([shipperId])
  @@map("orders")
}

model OrderStatusHistory {
  id            Int         @id @default(autoincrement())
  orderId       Int
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  previousStatus OrderStatus?
  nextStatus    OrderStatus
  note          String?     @db.Text
  createdAt     DateTime    @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  name      String
  sku       String
  selectedOptions Json?
  price     Decimal  @db.Decimal(12, 2)
  quantity  Int
  total     Decimal  @db.Decimal(12, 2)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model ShippingRate {
  id          Int      @id @default(autoincrement())
  provinceId  Int?     @unique
  province    Province? @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  label       String
  fee         Decimal  @db.Decimal(12, 2)
  freeFrom    Decimal? @db.Decimal(12, 2)
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isDefault])
  @@map("shipping_rates")
}

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String
  phone       String?
  email       String?
  address     String?
  description String?   @db.Text
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("suppliers")
}

model Shipper {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shippers")
}

model Province {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  orders    Order[]
  shippingRate ShippingRate?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("provinces")
}

model CustomerQuestion {
  id             Int      @id @default(autoincrement())
  userId         Int?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName   String
  customerEmail  String
  customerPhone  String?
  subject        String
  message        String   @db.Text
  isResolved     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@map("customer_questions")
}

model AiKnowledgeItem {
  id          Int      @id @default(autoincrement())
  title       String
  keywords    String   @db.Text
  answer      String   @db.Text
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@map("ai_knowledge_items")
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?  @db.Text
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
  @@map("reviews")
}

model SupportRequest {
  id            Int                  @id @default(autoincrement())
  userId        Int?
  orderId       Int?
  user          User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  order         Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type          SupportRequestType
  status        SupportRequestStatus @default(OPEN)
  customerName  String
  customerEmail String
  customerPhone String?
  subject       String
  message       String               @db.Text
  adminNote     String?              @db.Text
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@map("support_requests")
}

model Coupon {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  description    String?
  discountType   String
  discountValue  Decimal  @db.Decimal(12, 2)
  minOrderTotal  Decimal? @db.Decimal(12, 2)
  usageLimit     Int?
  usedCount      Int      @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("coupons")
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
